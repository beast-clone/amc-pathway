---
import Layout from '../layouts/Layout.astro';
import ChapterReader from '../components/ChapterReader.astro';
const RAW_BASE = import.meta.env.BASE_URL;
const BASE = RAW_BASE.endsWith('/') ? RAW_BASE : RAW_BASE + '/';

const chapters = [
  { n: '01', t: 'Introduction to the Australian Pathway', m: 'Free read' },
  { n: '02', t: 'English Language Requirements', m: '12 min' },
  { n: '03', t: 'EPIC Verification and AMC Portfolio Setup', m: '14 min' },
  { n: '04', t: 'AMC Exam Strategy and Preparation', m: '18 min' },
  { n: '05', t: 'AHPRA Registration', m: '10 min' },
  { n: '06', t: 'Salary, Financial Planning and Living Costs', m: '12 min' },
  { n: '07', t: 'Job Search Strategy and Interview Preparation', m: '13 min' },
  { n: '08', t: 'Workplace Based Assessment', m: '13 min' },
  { n: '09', t: 'Specialist Pathway', m: '15 min' },
  { n: '10', t: 'Competent Authority Pathway', m: '11 min' },
  { n: '11', t: 'Visa Pathways and Immigration', m: '12 min' },
  { n: '12', t: 'Permanent Residency and Citizenship', m: '10 min' },
  { n: '13', t: 'CPD Requirements', m: '9 min' },
  { n: '14', t: 'Life in Australia', m: '11 min' },
  { n: '15', t: 'Common Challenges and Solutions', m: '12 min' },
  { n: '16', t: 'Resources and Next Steps', m: '8 min' },
];

const stats = [
  { num: '16,900', sup: '+', label: 'Vacant medical positions in Australia in 2025.', src: 'Dept. of Health Workforce Report' },
  { num: '2.8', sup: '×', label: 'More than what most doctors earn back home.', src: '2025 salary comparison data' },
  { num: '65', sup: '%', label: 'Interview rate for IMGs at regional hospitals vs. 35% at metro.', src: 'IMG placement data, 2025' },
  { num: '98', sup: '%', label: 'Success rate for Workplace Based Assessment (WBA).', src: 'AMC WBA cohort outcomes' },
  { num: '76', sup: '%', label: 'Of IMGs report a better quality of life in Australia.', src: 'NRWA Workforce Insights' },
];

const testimonials = [
  {
    quote: 'I had spent <em>two years figuring this out alone.</em> The Blueprint compressed everything I\'d learned the hard way into one place. I wish I\'d had it on day one.',
    name: 'Dr. Aishwarya K.',
    role: 'MBBS, prepping for AMC MCQ',
    init: 'A',
  },
  {
    quote: 'Most resources tell you <em>what</em> the AMC is. This one tells you exactly <em>what to do next week</em> — and the week after. That\'s the difference.',
    name: 'Dr. Rohan S.',
    role: 'Currently in AHPRA registration',
    init: 'R',
  },
  {
    quote: 'The Workforce Plus and rural pathway chapter alone is worth it. <em>No one explains this clearly anywhere else.</em>',
    name: 'Dr. Meera P.',
    role: 'Awarded provisional registration, 2026',
    init: 'M',
  },
];

const faq = [
  {
    q: 'Who is this Blueprint for?',
    a: 'Final-year MBBS students and qualified Indian doctors who want a real, step-by-step path to working as a doctor in Australia — without spending two years assembling it from forums, YouTube and outdated PDFs.',
  },
  {
    q: 'Do I need prior knowledge of the Australian pathway?',
    a: 'No. The Blueprint starts from zero and assumes you are new to the AMC, AHPRA and Workforce Plus systems. Each chapter builds on the last in plain English.',
  },
  {
    q: 'Is the information up to date?',
    a: 'Yes. It reflects current AMC, AHPRA and Department of Health rules as of 2026, including the latest Workforce Plus reforms and the WBA pathway changes.',
  },
  {
    q: 'What format is the Blueprint in?',
    a: 'A clean, fully-searchable PDF you can read on phone, tablet or laptop. You get instant access by email the moment your payment goes through.',
  },
  {
    q: 'What if I cannot afford to pay through my AMC journey?',
    a: 'The Blueprint includes a full chapter on funding, scholarships, bridging-loan options and how IMGs sequence costs so the pathway is realistic on a working doctor\'s salary.',
  },
  {
    q: 'Is this a one-time purchase?',
    a: 'Yes — pay once, keep forever. All updates we publish in 2026 are included free.',
  },
];
---

<Layout>
  <!-- ========== NAV ========== -->
  <nav class="nav">
    <div class="nav-inner">
      <a class="brand" href="#top">
        <img class="brand-logo" src={`${BASE}goocampus-logo.png`} alt="GooCampus Australia" />
        <span class="brand-text">AMC Pathway Blueprint for IMGs</span>
      </a>
      <div class="nav-meta">
        <a class="meta-link" href="#inside">What's inside</a>
        <a class="meta-link" href="#faq">FAQ</a>
        <a class="btn btn-red nav-cta" href="https://rzp.io/rzp/tMthGCGv" target="_blank" rel="noopener">Get the Blueprint</a>
      </div>
    </div>
  </nav>

  <!-- ========== HERO ========== -->
  <header class="hero" id="top">
    <div class="wrap hero-grid">
      <div class="hero-left">
        <span class="eyebrow"><span class="dot"></span>The IMG Edition · 2026 Revision</span>
        <h1 class="h-display">
          The complete guide<br />
          to becoming a doctor<br />
          <em>in Australia.</em>
        </h1>
        <p class="lede">
          One pathway. 16 chapters. Every step every IMG needs — from AMC strategy to AHPRA registration to the rural Workforce Plus route — written without the noise.
        </p>
        <div class="hero-meta">
          <div class="price-block">
            <span class="price-old">₹2,499</span>
            <span class="price-now"><span class="rs">₹</span>999</span>
          </div>
          <span class="price-tag">Launch price · Instant access</span>
        </div>
        <div class="hero-cta-row">
          <a class="btn btn-primary" href="https://rzp.io/rzp/tMthGCGv" target="_blank" rel="noopener">
            Get your copy now
            <span class="arr">→</span>
          </a>
          <a class="btn btn-ghost" href="#inside">View what's inside</a>
        </div>
      </div>
      <div class="book-stage">
        <div class="book book-with-cover">
          <img class="book-cover-img" src={`${BASE}book-cover.png`} alt="Australia AMC Pathway Blueprint — 16-chapter guide for IMGs" />
          <div class="book-stamp book-stamp-call">
            <span class="bs-num">30 MIN</span>
            <span class="bs-label">EXPERT<br/>CALL</span>
            <span class="bs-sub">INCLUDED</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== TRUST STRIP ========== -->
  <section class="strip">
    <div class="wrap strip-inner">
      <div class="strip-item"><span class="ico">★</span> 4.8 · 86+ verified readers</div>
      <div class="strip-rule"></div>
      <div class="strip-item"><span class="ico">✓</span> Reflects 2026 AHPRA & Workforce Plus rules</div>
      <div class="strip-rule"></div>
      <div class="strip-item"><span class="ico">↓</span> Instant PDF · 220 pages</div>
      <div class="strip-rule"></div>
      <div class="strip-item"><span class="ico">⤓</span> Free 2026 updates included</div>
    </div>
  </section>

  <!-- ========== INTRO ========== -->
  <section class="intro">
    <div class="wrap intro-grid">
      <div class="left">
        <span class="eyebrow"><span class="dot"></span>Why this exists</span>
        <h2 class="h-section">One guide.<br /><em>Every answer.</em></h2>
      </div>
      <div class="right">
        <p class="body-l dropcap">
          Most IMGs spend 12 to 24 months piecing together the Australian pathway from outdated forum threads, conflicting YouTube videos and PDFs from 2019. By the time the map is clear, the window has often closed.
        </p>
        <p>
          The AMC Pathway Blueprint exists for one reason: to give every Indian medical graduate the same complete, current, sequenced answer — in one place, in one weekend's read.
        </p>
        <div class="pull-quote">
          "If I had to start over today, this is the only guide I would want on my desk."
        </div>
        <p>
          Every chapter has been reviewed against current AMC, AHPRA and Department of Health policy. Nothing is decorative. Every page exists because, without it, an IMG somewhere will miss a step that costs them a year.
        </p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT YOU'LL KNOW ========== -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>What changes after reading</span>
        <h2 class="h-section">Here's exactly what <em>the Blueprint gives you.</em></h2>
        <p>Five outcomes — all decisive.</p>
      </div>
      <div class="cards-2">
        <div class="know-card">
          <div class="know-num">01</div>
          <div>
            <h4>You'll know exactly which pathway applies to you</h4>
            <p>Standard, Competent Authority, or Specialist — with timelines, costs and eligibility clearly laid out, so you never waste time on the wrong path.</p>
          </div>
        </div>
        <div class="know-card">
          <div class="know-num">02</div>
          <div>
            <h4>You'll never miss a hiring window again</h4>
            <p>Every state hiring window, interview format and application requirement is laid out, so you apply at the right time to the right state.</p>
          </div>
        </div>
        <div class="know-card">
          <div class="know-num">03</div>
          <div>
            <h4>You'll understand your AHPRA registration at every stage</h4>
            <p>Which registration type you hold, what it allows you to do, and exactly when and how to upgrade — so your work rights are never restricted unnecessarily.</p>
          </div>
        </div>
        <div class="know-card">
          <div class="know-num">04</div>
          <div>
            <h4>You'll have a clear visa and PR strategy before you land</h4>
            <p>The new Skills in Demand visa, all PR pathways, and the regional advantage strategy that most IMGs completely overlook.</p>
          </div>
        </div>
        <div class="know-card">
          <div class="know-num">05</div>
          <div>
            <h4>You'll know exactly what to budget for</h4>
            <p>Complete cost breakdown from EPIC verification to relocation — so there are no financial surprises at any stage.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== STATS — WHY AUSTRALIA NOW ========== -->
  <section class="stats-block">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>The window is open</span>
        <h2 class="h-section">Why Australia. <em>Why now.</em></h2>
        <p>The numbers Indian medical graduates rarely see in one place.</p>
      </div>
      <div class="stats-grid">
        {stats.map(s => (
          <div class="stat">
            <div class="num">{s.num}<em>{s.sup}</em></div>
            <div class="label">{s.label}</div>
            <div class="src">Source · {s.src}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CHAPTERS ========== -->
  <section class="section" id="inside">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>What's inside</span>
        <h2 class="h-section">16 chapters.<br /><em>Every stage. Nothing missing.</em></h2>
        <p>The full table of contents. The first chapter is free to read before you buy.</p>
      </div>
      <div class="toc">
        <div class="toc-item">
          <button class="toc-row toc-row-btn" type="button" data-reader-open>
            <div class="toc-num">01</div>
            <div class="toc-title">Introduction to the Australian Pathway</div>
            <div class="toc-meta is-new">Read free <span class="toc-caret">→</span></div>
          </button>
        </div>
        {chapters.slice(1).map(c => (
          <div class="toc-item is-locked">
            <div class="toc-row">
              <div class="toc-num">{c.n}</div>
              <div class="toc-title">{c.t}</div>
              <div class="toc-meta">
                <span class="toc-lock" aria-label="Locked" title="Locked">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="4" y="11" width="16" height="10" rx="2"></rect>
                    <path d="M8 11V8a4 4 0 0 1 8 0v3"></path>
                  </svg>
                </span>
                <span class="toc-meta-text">{c.m}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="chapters-cta">
        <div class="hero-meta" style="display:inline-flex; border-top:none; padding-top:0; margin-bottom:20px;">
          <div class="price-block">
            <span class="price-old">₹2,499</span>
            <span class="price-now"><span class="rs">₹</span>999</span>
          </div>
          <span class="price-tag">only</span>
        </div>
        <div>
          <a class="btn btn-red" href="https://rzp.io/rzp/tMthGCGv" target="_blank" rel="noopener">Get your copy now →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== COMPARISON ========== -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>The honest comparison</span>
        <h2 class="h-section">The Blueprint <em>vs.</em><br />Figuring it out alone.</h2>
      </div>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th class="ct-row-label"></th>
              <th class="ct-bp">⚡ The Blueprint</th>
              <th class="ct-alone">Figuring It Out Alone</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="ct-row-label">Time to get clarity</td>
              <td class="ct-bp"><span class="ct-tick">✓</span> One read</td>
              <td class="ct-alone"><span class="ct-cross">✕</span> Months to years</td>
            </tr>
            <tr>
              <td class="ct-row-label">Information accuracy</td>
              <td class="ct-bp"><span class="ct-tick">✓</span> Verified 2025 data</td>
              <td class="ct-alone"><span class="ct-cross">✕</span> Mixed and outdated</td>
            </tr>
            <tr>
              <td class="ct-row-label">Pathway coverage</td>
              <td class="ct-bp"><span class="ct-tick">✓</span> All 3 pathways</td>
              <td class="ct-alone"><span class="ct-cross">✕</span> Usually only Standard</td>
            </tr>
            <tr>
              <td class="ct-row-label">Cost breakdown</td>
              <td class="ct-bp"><span class="ct-tick">✓</span> Every stage covered</td>
              <td class="ct-alone"><span class="ct-cross">✕</span> Incomplete</td>
            </tr>
            <tr>
              <td class="ct-row-label">Job search strategy</td>
              <td class="ct-bp"><span class="ct-tick">✓</span> State wise with timelines</td>
              <td class="ct-alone"><span class="ct-cross">✕</span> Generic</td>
            </tr>
            <tr>
              <td class="ct-row-label">Visa and PR guidance</td>
              <td class="ct-bp"><span class="ct-tick">✓</span> Complete end to end</td>
              <td class="ct-alone"><span class="ct-cross">✕</span> Rarely covered</td>
            </tr>
            <tr>
              <td class="ct-row-label">Cost</td>
              <td class="ct-bp ct-price"><span class="ct-tick">✓</span> ₹999</td>
              <td class="ct-alone"><span class="ct-cross">✕</span> Free but costs you time</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="chapters-cta" style="margin-top:32px;">
        <div>
          <a class="btn btn-red" href="https://rzp.io/rzp/tMthGCGv" target="_blank" rel="noopener">Get your copy now →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FOR YOU IF ========== -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>Honest fit</span>
        <h2 class="h-section">The Blueprint is for you if —</h2>
      </div>
      <div class="foryou-grid">
        <div class="foryou-card">
          <span class="foryou-mark">→</span>
          <p>You are an MBBS or MD graduate planning to move to Australia, and you want one sequenced map instead of forty open tabs.</p>
        </div>
        <div class="foryou-card">
          <span class="foryou-mark">→</span>
          <p>You have been preparing for AMC, IELTS or OET on and off, and you cannot tell whether you are actually closer than a year ago.</p>
        </div>
        <div class="foryou-card">
          <span class="foryou-mark">→</span>
          <p>You are already registered for AMC and want to know whether the WBA or rural route would get you on a roster faster than the standard pathway.</p>
        </div>
        <div class="foryou-card">
          <span class="foryou-mark">→</span>
          <p>You are budgeting the next two years and need an honest, line-by-line view of what each step actually costs in 2026.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIALS ========== -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>What IMGs are saying</span>
        <h2 class="h-section">Doctors who read it <em>before they began.</em></h2>
      </div>
      <div class="testi-grid">
        {testimonials.map(t => (
          <div class="testi-card">
            <div class="testi-stars">★★★★★</div>
            <div class="testi-quote" set:html={`"${t.quote}"`}></div>
            <div class="testi-author">
              <div class="testi-ava">{t.init}</div>
              <div>
                <div class="testi-name">{t.name}</div>
                <div class="testi-role">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== BONUS · FREE CONSULTATION ========== -->
  <section class="guarantee">
    <div class="wrap-narrow">
      <div class="guarantee-card">
        <div class="guarantee-seal">
          <div class="guarantee-seal-inner">
            <div class="guarantee-seal-num">30</div>
            <div class="guarantee-seal-label">MIN<br/>CALL</div>
          </div>
        </div>
        <div class="guarantee-body">
          <span class="eyebrow"><span class="dot"></span>Included with your copy</span>
          <h2 class="h-section">A free 30-minute call <em>with our expert counsellors.</em></h2>
          <p class="guarantee-lede">
            Every reader who buys the Blueprint gets a complimentary one-on-one call with our expert Australia counsellors — no booking fee, no upsell. Ask anything the book leaves you wanting to discuss in person.
          </p>
          <div class="guarantee-options">
            <div class="guarantee-option">
              <div class="guarantee-option-mark">01</div>
              <div>
                <h4>Personalised pathway review</h4>
                <p>We look at your stage — MBBS year, AMC progress, IELTS/OET status — and map the fastest realistic next step for you.</p>
              </div>
            </div>
            <div class="guarantee-option">
              <div class="guarantee-option-mark">02</div>
              <div>
                <h4>Direct answers from our expert counsellors</h4>
                <p>Our expert Australia counsellors will call you within 48 hours of purchase. No queues, no forms — just a straight conversation.</p>
              </div>
            </div>
          </div>
          <p class="guarantee-foot">
            Worth ₹2,499 — yours free, the moment your order goes through.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section" id="faq">
    <div class="wrap-narrow">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>Before you buy</span>
        <h2 class="h-section">Frequently asked <em>questions.</em></h2>
      </div>
      <div class="faq-list">
        {faq.map(f => (
          <div class="faq-item">
            <button class="faq-q" type="button">
              {f.q}
              <span class="plus">+</span>
            </button>
            <div class="faq-a"><p>{f.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== FINAL CTA ========== -->
  <section class="final" id="buy">
    <div class="wrap-narrow">
      <span class="eyebrow" style="color:#E0A5A0; display:block; margin-bottom:22px;"><span class="dot" style="background:#E0A5A0;"></span>Launch price · Limited window</span>
      <h2 class="h-section">Begin the pathway<br /><em>this weekend.</em></h2>
      <p>The Blueprint is one decision away. The AMC, AHPRA and Workforce Plus systems will not wait — but the launch price will only hold for the first 500 copies.</p>
      <div class="final-price">
        <span class="price-old">₹2,499</span>
        <span class="price-now"><span class="rs">₹</span>999</span>
      </div>
      <div>
        <a class="btn btn-red" href="https://rzp.io/rzp/tMthGCGv" target="_blank" rel="noopener" style="font-size:16px; padding:18px 36px;">Get your copy now →</a>
      </div>
      <div class="final-note">Instant PDF · Free 2026 updates · One-time payment</div>
    </div>
  </section>

  <!-- ========== FOOTER ========== -->
  <footer class="footer">
    <div class="wrap">
      <div class="footer-grid">
        <div>
          <div class="footer-brand">GooCampus · AMC Pathway Blueprint</div>
          <p>GooCampus helps Indian medical graduates build credentialed, sequenced pathways to global practice — without the noise.</p>
        </div>
        <div class="footer-links">
          <a href="#inside">Inside the book</a>
          <a href="#faq">FAQ</a>
          <a href="mailto:info@goocampus.in">Contact</a>
        </div>
      </div>
      <div class="footer-bottom">
        <div>© 2026 GooCampus. All rights reserved.</div>
        <div>Made with care for IMGs.</div>
      </div>
    </div>
  </footer>

  <!-- ========== PAYMENT SUCCESS MODAL ========== -->
  <div class="success-modal" id="successModal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="success-backdrop" data-close></div>
    <div class="success-card">
      <button class="success-close" type="button" data-close aria-label="Close">×</button>
      <div class="success-check">
        <svg viewBox="0 0 52 52" width="56" height="56" aria-hidden="true">
          <circle cx="26" cy="26" r="24" fill="none" stroke="#1f9d55" stroke-width="3"/>
          <path d="M14 27 L23 36 L39 18" fill="none" stroke="#1f9d55" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3>Payment received — welcome aboard!</h3>
      <p class="success-lede">
        Your copy of the <strong>AMC Pathway Blueprint</strong> is on its way. A GooCampus expert counsellor will also call you within 48 hours for your free 30-minute consultation.
      </p>
      <div class="success-channels">
        <div class="success-row">
          <span class="success-ico">✉</span>
          <div>
            <strong>Email confirmation</strong>
            <p>Sent to the email you used at checkout — includes your Blueprint PDF download link.</p>
          </div>
        </div>
        <div class="success-row">
          <span class="success-ico">✆</span>
          <div>
            <strong>WhatsApp confirmation</strong>
            <p>A message will arrive on the WhatsApp number you used at checkout.</p>
          </div>
        </div>
      </div>
      <div class="success-spam">
        <strong>Don't see it in a few minutes?</strong> Please check your <em>Spam</em> or <em>Promotions</em> folder — confirmation emails sometimes land there. If you still cannot find it, write to <a href="mailto:info@goocampus.in">info@goocampus.in</a> and we will resend it within the hour.
      </div>
      <button class="btn btn-red success-cta" type="button" data-close>Got it — close</button>
    </div>
  </div>

  <script is:inline>
    (function () {
      try {
        var params = new URLSearchParams(window.location.search);
        var paid = params.get('payment') === 'success' || params.get('razorpay_payment_id');
        if (!paid) return;
        var modal = document.getElementById('successModal');
        if (!modal) return;
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        function close() {
          modal.classList.remove('is-open');
          modal.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
          var url = new URL(window.location.href);
          url.searchParams.delete('payment');
          url.searchParams.delete('razorpay_payment_id');
          url.searchParams.delete('razorpay_payment_link_id');
          url.searchParams.delete('razorpay_payment_link_reference_id');
          url.searchParams.delete('razorpay_payment_link_status');
          url.searchParams.delete('razorpay_signature');
          window.history.replaceState({}, '', url.pathname + (url.search ? '?' + url.searchParams.toString() : '') + url.hash);
        }
        modal.querySelectorAll('[data-close]').forEach(function (el) { el.addEventListener('click', close); });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
      } catch (err) { /* noop */ }
    })();
  </script>

